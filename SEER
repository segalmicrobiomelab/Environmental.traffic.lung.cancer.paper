# Fit one cross-sectional model and return the exposure estimate with HC3 inference
estimate_exposure <- function(year_value, exposure_var) {
  model <- lm(
    reformulate(c(exposure_var, covariates), response = "Rate_adj"),
    data = filter(analysis_data, year == year_value)
  )
  
  hc3 <- sandwich::vcovHC(model, type = "HC3")
  test <- lmtest::coeftest(model, vcov. = hc3)
  ci <- lmtest::coefci(model, vcov. = hc3)
  
  tibble::tibble(
    year = year_value,
    exposure = exposure_var,
    beta = test[exposure_var, "Estimate"],
    ci_lower = ci[exposure_var, 1],
    ci_upper = ci[exposure_var, 2],
    p_value = test[exposure_var, "Pr(>|t|)"]
  )
}

