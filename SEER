  ) %>%
  ungroup()

#calculate the total average population
total_study_pop <- sum(seer_aggregated$mean_population, na.rm = TRUE)

# Weight by County Population
weighted_design <- svydesign(ids = ~1, weights = ~mean_population, data = seer_aggregated)

# CREATE WEIGHTED TABLE ONE
vars_to_summarize <- c("Rate_adj", "PM2.5_pre5_mean", "Traffic_pre5_mean", "no_traffic_pre5_mean", 
                        "age65_perc", "rural_perc", "black_perc", "hispanic_perc", 
                       "asian_perc", "Median.household.income.raw.value", 
                       "smoke_prev_2011", "Air.pollution.ozone.days.raw.value", 
                       "radon_zone1_pct")

tab1_obj <- svyCreateTableOne(vars = vars_to_summarize, data = weighted_design)

# PREPARE THE DATA FOR GT (MANUAL LABELING)
tab1_matrix <- print(tab1_obj, printToggle = FALSE, noSpaces = TRUE, varLabels = FALSE)
