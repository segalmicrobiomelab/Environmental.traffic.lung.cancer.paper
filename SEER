  summarise(
    mean_population = mean(Population, na.rm = TRUE),
    Rate_adj = mean(Rate_adj, na.rm = TRUE),
    PM2.5_pre5_mean = mean(PM2.5_pre5_mean, na.rm = TRUE),
    Traffic_pre5_mean = mean(Traffic_pre5_mean, na.rm = TRUE),
