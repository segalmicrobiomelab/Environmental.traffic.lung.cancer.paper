library(dplyr)
library(dlnm)
library(fixest)
library(ggplot2)

seer_fips <- readRDS("SEER_PM.rds")

outcome_year_min <- 2011
outcome_year_max <- 2019
max_lag <- 10
exposure_year_min <- outcome_year_min - max_lag
lag_basis <- list(fun = "ns", df = 3)
rate_offset <- 1e-6

fit_dlnm_curve <- function(exposure_var, exposure_label) {
  panel <- seer_fips %>%
    select(
      county_fips, state, year, Population, Rate_adj,
      exposure = all_of(exposure_var)
    ) %>%
    filter(year >= exposure_year_min, year <= outcome_year_max) %>%
    arrange(county_fips, year) %>%
    group_by(county_fips) %>%
    filter(
      min(year) == exposure_year_min,
      max(year) == outcome_year_max,
      n() == outcome_year_max - exposure_year_min + 1
    ) %>%
    ungroup()
  
  cross_basis <- crossbasis(
    panel$exposure,
    lag = c(0, max_lag),
    argvar = list(fun = "lin"),
    arglag = lag_basis,
    group = panel$county_fips
  )
  
  basis_data <- as.data.frame(cross_basis)
  basis_names <- paste0("cb_", seq_len(ncol(basis_data)))
  names(basis_data) <- basis_names
  
  analysis_data <- bind_cols(panel, basis_data) %>%
    filter(
      year >= outcome_year_min,
      year <= outcome_year_max,
      is.finite(Rate_adj),
      if_all(all_of(basis_names), ~ is.finite(.x)),
      is.finite(Population),
      Population > 0
    )
  
  model_formula <- as.formula(
    paste0(
      "log(Rate_adj + ", rate_offset, ") ~ ",
      paste(basis_names, collapse = " + "),
      " | county_fips + state^year"
    )
  )
  
  model <- feols(
    model_formula,
    data = analysis_data,
    weights = ~ Population,
    vcov = ~ county_fips
  )
  
  coefficients <- coef(model)[basis_names]
  covariance <- vcov(model)[basis_names, basis_names, drop = FALSE]
  reference <- median(analysis_data$exposure, na.rm = TRUE)
  
  prediction <- crosspred(
    cross_basis,
    coef = coefficients,
    vcov = covariance,
    cen = reference,
    at = reference + 1
  )
  
  data.frame(
    exposure = exposure_label,
    lag = 0:max_lag,
    rr = exp(as.vector(prediction$matfit[1, ])),
    low = exp(as.vector(prediction$matlow[1, ])),
    high = exp(as.vector(prediction$mathigh[1, ]))
  )
}

plot_data <- bind_rows(
  fit_dlnm_curve("Traffic_weighted_mean", "Traffic PM2.5"),
  fit_dlnm_curve("no_traffic_weighted_mean", "Non-traffic PM2.5")
) %>%
