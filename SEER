label(seer_filtered$Traffic_pre5_mean) <- "Traffic PM2.5 (µg/m³)"
label(seer_filtered$no_traffic_pre5_mean) <- "Non-traffic PM2.5 (µg/m³)"
label(seer_filtered$age65_perc) <- "% ≥65 years"
label(seer_filtered$rural_perc) <- "% Rural"
label(seer_filtered$black_perc) <- "% Black"
label(seer_filtered$hispanic_perc) <- "% Hispanic"
label(seer_filtered$asian_perc) <- "% Asian"
label(seer_filtered$Median.household.income.raw.value) <- "Median Household Income ($)"
label(seer_filtered$smoke_prev_2011) <- "Smoking Prevalence (2011, %)"
