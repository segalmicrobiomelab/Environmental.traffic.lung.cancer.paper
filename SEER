# Construct a legend with the highest interval displayed first
reverse_legend <- function(values, palette, title, digits) {
  finite_values <- values[is.finite(values)]
  
  if (!length(finite_values)) {
    return(list(
      colors = "#e0e0e0",
      labels = "NA",
      title = title
    ))
  }
  
  value_range <- range(finite_values)
  breaks <- pretty(value_range, n = 6)
  breaks <- breaks[breaks >= value_range[1] & breaks <= value_range[2]]
  breaks <- sort(unique(c(value_range, breaks)))
  
  if (length(breaks) < 2) {
    breaks <- value_range
  }
  
  midpoints <- (head(breaks, -1) + tail(breaks, -1)) / 2
  labels <- paste0(
    formatC(head(breaks, -1), format = "f", digits = digits),
    " – ",
    formatC(tail(breaks, -1), format = "f", digits = digits)
  )
  
  list(
    colors = rev(palette(midpoints)),
    labels = rev(labels),
    title = title
  )
}

background_js <- "function(el, x) {
  var style = document.createElement('style');
  style.innerHTML = '.leaflet-container { background: #e6f2ff; }';
  el.appendChild(style);
}"

make_county_map <- function(
    data, variable, palette, legend_title, legend_digits,
    popup_label, popup_digits, popup_suffix = ""
) {
  values <- data[[variable]]
  legend <- reverse_legend(values, palette, legend_title, legend_digits)
  
  leaflet(data, options = leafletOptions(zoomSnap = 0.25)) %>%
    addTiles(
      urlTemplate = "",
      attribution = NULL,
      options = tileOptions(minZoom = 3, maxZoom = 18)
    ) %>%
    addPolygons(
      fillColor = palette(values),
      fillOpacity = 0.7,
      weight = 0.3,
      color = "#444",
      popup = paste0(
        data$NAME, ", ", data$STUSPS, "<br>", popup_label,
        ifelse(is.na(values), "NA", round(values, popup_digits)),
        popup_suffix
      )
    ) %>%
    addLegend(
      position = "bottomright",
      colors = legend$colors,
      labels = legend$labels,
      opacity = 0.7,
      title = legend$title
    ) %>%
    fitBounds(lng1 = -125, lat1 = 24, lng2 = -66, lat2 = 49) %>%
    htmlwidgets::onRender(background_js)
}

