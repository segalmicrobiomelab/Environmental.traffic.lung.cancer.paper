Mouse GSEA figure 4D
```{r}
########################################
# GSEA helper: MSigDB Hallmark, mouse symbols
# Select within this codeblock if you want to run Hallmark, GSEA, or Gene Ontology:BP
########################################

run_mouse_gsea <- function(results, title, p_cutoff = 0.05, showCategory = 8) {
  
  ########################################
  # Prepare ranked gene list
  ########################################
  
  res <- results %>%
    as.data.frame() %>%
    mutate(
      Gene.symbol = if ("gene" %in% colnames(.)) gene else rownames(.),
      logFC = as.numeric(logFC),
      PValue = as.numeric(PValue),
      rank_stat = sign(logFC) * -log10(PValue)
    ) %>%
    filter(
      !is.na(Gene.symbol),
      Gene.symbol != "",
      !is.na(rank_stat),
      is.finite(rank_stat)
    )
  
  gene_list <- res$rank_stat
  names(gene_list) <- res$Gene.symbol
  
  # Collapse duplicate gene symbols, keeping strongest absolute statistic
  gene_list <- tapply(gene_list, names(gene_list), function(x) {
    x[which.max(abs(x))]
  })
  
  gene_list <- setNames(as.numeric(gene_list), names(gene_list))
  gene_list <- sort(gene_list, decreasing = TRUE)
  
  ########################################
  # Get mouse Hallmark gene sets
  ########################################

#Hallmark
  msig_collection <- msigdbr(
    species = "Mus musculus",
    collection = "H"
  )
  

clean_hallmark_label <- function(x) {
  x %>%
    str_remove("^HALLMARK[ _]+") %>%   
    str_replace_all("_", " ")          
}

#  # Reactome  
#  msig_collection <- msigdbr(
#  species = "Mus musculus",
#  collection = "C2",
#  subcollection = "CP:REACTOME"
#  )
  
  # Gene Ontology: Biological Process
#  msig_collection <- msigdbr(
#  species = "Mus musculus",
#  collection = "C5",
#  subcollection = "GO:BP"
#  )

  term2gene_df <- msig_collection %>%
    dplyr::select(gs_name, gene_symbol) %>%
    dplyr::rename(
      term = gs_name,
      gene = gene_symbol
    ) %>%
    dplyr::distinct()
  
  overlap_n <- length(intersect(names(gene_list), term2gene_df$gene))
  message(title, " — genes overlapping MSigDB Hallmark: ", overlap_n)
  
  ########################################
  # Run GSEA
  ########################################
  
  set.seed(42)
  
  gsea_result <- GSEA(
    geneList = gene_list,
    TERM2GENE = term2gene_df,
    pvalueCutoff = p_cutoff,
    pAdjustMethod = "BH",
    minGSSize = 10,
    maxGSSize = 500,
    verbose = FALSE,
    seed = TRUE
  )
  
  ########################################
  # Dotplot: cleaner RMD-friendly version
  ########################################
  
dot <- dotplot(
  gsea_result,
  showCategory = showCategory,
  split = ".sign",
  color = "p.adjust",
  label_format = 40
) +
  facet_grid(. ~ .sign) +
  ggtitle(paste0("Top Enriched Pathways: ", title)) +
  scale_y_discrete(labels = clean_hallmark_label) +
  theme_bw(base_size = 12) +
  theme(
    axis.text.y = element_text(size = 9, color = "black"),
    axis.text.x = element_text(size = 10, color = "black"),
    axis.title = element_text(size = 12, face = "bold"),
    plot.title = element_text(size = 14, face = "bold", hjust = 0.5),
    strip.text = element_text(size = 11, face = "bold"),
    legend.position = "right",
    legend.title = element_text(size = 10, face = "bold"),
    legend.text = element_text(size = 9)
  )
  
  
  print(dot)
  
  ########################################
  # Cnetplot: pathway labels only
  ########################################

# Create a temporary plotting copy with cleaned Hallmark pathway names
gsea_result_cnet <- gsea_result

gsea_result_cnet@result$Description <- clean_hallmark_label(
  gsea_result_cnet@result$Description
)

cnet <- cnetplot(
  gsea_result_cnet,
  showCategory = showCategory,
  foldChange = gene_list,
  node_label = "category"
) +
  scale_colour_gradient2(
    low = "blue",
    mid = "white",
    high = "red",
    midpoint = 0
  ) +
  ggtitle(paste0("Pathway–Gene Network: ", title)) +
  theme(
    plot.title = element_text(
      size = 14,
      face = "bold",
      hjust = 0.5
    )
  )

print(cnet)

  ########################################
  # Ridgeplot
  ########################################
  
  ridge <- ridgeplot(
    gsea_result,
    showCategory = showCategory
  ) +
    ggtitle(paste0("GSEA Ridgeplot: ", title)) +
    theme_bw(base_size = 12) +
    theme(
      plot.title = element_text(size = 14, face = "bold", hjust = 0.5),
      axis.text.y = element_text(size = 9, color = "black")
    )
  
  print(ridge)
  
  return(list(
    gsea_result = gsea_result,
    gene_list = gene_list,
    dotplot = dot,
    cnetplot = cnet,
    ridgeplot = ridge
  ))
}
