Mouse transcriptome DGE: edgeR-only QL GLM
```{r}

library(edgeR)
library(dplyr)
library(stringr)
library(ggplot2)
library(ggrepel)
library(msigdbr)
library(clusterProfiler)

########################################
# Load and prepare counts
########################################

mouse_counts <- read.delim2("RNA_Host_Transcriptome_cohort2.tsv", check.names = FALSE)

rownames(mouse_counts) <- make.unique(as.character(mouse_counts$gene))
mouse_counts$gene <- NULL

# Build metadata from original column names
sample_names <- colnames(mouse_counts)

mouse_metadata <- data.frame(sample_name = sample_names) %>%
  mutate(
    sample_name = str_remove(sample_name, "\\.L00[0-9]$"),
    mouse_id = str_extract(sample_name, "^M[0-9]+"),
    pollution_type = str_extract(str_to_lower(sample_name), "nontraffic|traffic|pbs")
  ) %>%
  distinct(sample_name, .keep_all = TRUE)

rownames(mouse_metadata) <- mouse_metadata$sample_name

# Sum lanes from the same biological sample
clean_sample_names <- str_remove(colnames(mouse_counts), "\\.L00[0-9]$")
mouse_counts <- t(rowsum(t(as.matrix(mouse_counts)), group = clean_sample_names))

# Align metadata and counts
mouse_metadata <- mouse_metadata[colnames(mouse_counts), , drop = FALSE]

########################################
# Subset to groups of interest
########################################

v <- "pollution_type"

mouse_metadata[[v]] <- factor(
  mouse_metadata[[v]],
  levels = c("pbs", "traffic", "nontraffic")
)

keep_samples <- !is.na(mouse_metadata[[v]]) &
  mouse_metadata[[v]] %in% c("pbs", "traffic", "nontraffic")

mouse_metadata_analysis <- mouse_metadata[keep_samples, , drop = FALSE]
mouse_counts_analysis <- mouse_counts[, rownames(mouse_metadata_analysis), drop = FALSE]

stopifnot(all(colnames(mouse_counts_analysis) == rownames(mouse_metadata_analysis)))

table(mouse_metadata_analysis[[v]])
colSums(mouse_counts_analysis)

########################################
# edgeR QL GLM
########################################

group <- mouse_metadata_analysis[[v]]

dge <- DGEList(
  counts = mouse_counts_analysis,
  group = group
)

design <- model.matrix(~ 0 + group)
colnames(design) <- levels(group)

# edgeR expression filtering
keep_genes <- filterByExpr(dge, design = design)

cat("Genes before filtering:", nrow(dge), "\n")
cat("Genes after filtering:", sum(keep_genes), "\n")

dge <- dge[keep_genes, , keep.lib.sizes = FALSE]

# TMM normalization
dge <- calcNormFactors(dge, method = "TMM")

# Diagnostics
plotMDS(
  dge,
  labels = group,
  col = as.numeric(group),
  main = "MDS plot: mouse transcriptome"
)

legend(
  "topright",
  legend = levels(group),
  col = seq_along(levels(group)),
  pch = 16,
  bty = "n"
)

# Dispersion and QL GLM fit
dge <- estimateDisp(dge, design)
plotBCV(dge)

fit <- glmQLFit(dge, design, robust = TRUE)

########################################
# Pairwise contrast
########################################

contrast_nontraffic_vs_traffic <- makeContrasts(
  traffic - nontraffic,
  levels = design
)

qlf_nontraffic_vs_traffic <- glmQLFTest(
  fit,
  contrast = contrast_nontraffic_vs_traffic
)

results_nontraffic_vs_traffic <- topTags(
  qlf_nontraffic_vs_traffic,
  n = Inf
)$table

# Add gene column
results_nontraffic_vs_traffic$gene <- rownames(results_nontraffic_vs_traffic)

# Positive logFC interpretation:
# results_nontraffic_vs_traffic:  positive = higher in traffic vs nontraffic

