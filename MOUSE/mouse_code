Volcano plots
```{r}
########################################
# Volcano plot helper
########################################

make_volcano <- function(results, title, alpha = 0.05) {
  

  res <- results %>%
    as.data.frame() %>%
    mutate(
      Gene.symbol = if ("gene" %in% colnames(.)) gene else rownames(.),
      logFC = as.numeric(logFC),
      PValue = as.numeric(PValue),
      FDR = as.numeric(FDR)
    ) %>%
    filter(!is.na(logFC), !is.na(PValue), !is.na(FDR)) %>%
    mutate(
      FDR_plot = pmax(FDR, .Machine$double.xmin),
      sig = -log10(FDR_plot),
      status = case_when(
        logFC > 0 & FDR < alpha ~ "Up",
        logFC < 0 & FDR < alpha ~ "Down",
        TRUE ~ "NS"
      ),
      label = ifelse(status == "NS", NA, Gene.symbol)
    )
  
res <- res %>%
  mutate(
    FDR_plot = pmax(FDR, .Machine$double.xmin),
    sig = -log10(FDR_plot),
    status = case_when(
      logFC > 0 & FDR < alpha ~ "Up",
      logFC < 0 & FDR < alpha ~ "Down",
      TRUE ~ "NS"
    )
  ) %>%
  group_by(status) %>%
  arrange(FDR, .by_group = TRUE) %>%
  mutate(
    label = ifelse(status != "NS" & row_number() <= 10, Gene.symbol, NA)
  ) %>%
  ungroup()
  
    
  p <- ggplot(res, aes(x = logFC, y = sig)) +
    geom_point(aes(color = status), alpha = 0.8, size = 1.8) +
    geom_text_repel(
      aes(label = label),
      size = 4,
      force = 25,
      segment.color = "grey",
      segment.alpha = 0.5,
      na.rm = TRUE,
      max.overlaps = 10
    ) +
    geom_hline(
      yintercept = -log10(alpha),
      color = "red",
      linetype = "dashed"
    ) +
    scale_color_manual(
      values = c("Up" = "red", "Down" = "blue", "NS" = "grey70")
    ) +
    labs(
      title = title,
      x = expression("Effect size: log"[2]*"FC"),
      y = expression("-log"[10]*"(FDR)")
    ) +
    theme_bw() +
    theme(
      panel.grid.major = element_line(linetype = "dashed", linewidth = 0.5, colour = "grey80"),
      panel.grid.minor = element_blank(),
      strip.background = element_blank(),
      axis.title = element_text(size = 20, face = "bold"),
      axis.text.x = element_text(colour = "black", size = 10),
      axis.text.y = element_text(colour = "black", size = 10),
      axis.ticks = element_blank(),
      legend.position = "none"
    )
  
  print(p)
  message("Genes with FDR < ", alpha, ": ", sum(res$FDR < alpha, na.rm = TRUE))
  
  invisible(res)
}

volcano_nontraffic_vs_traffic <- make_volcano(
  results_nontraffic_vs_traffic,
  "Traffic vs Nontraffic"
)

